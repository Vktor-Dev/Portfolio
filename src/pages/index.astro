---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projects = [
  {
    title: 'AWS Study Hub',
    description: 'App web interactiva para preparar el examen AWS AI Practitioner. Quiz por dominio, flashcards, notas organizadas y tracker de progreso. Construida con React y Vite.',
    tags: ['React', 'Vite', 'TypeScript', 'AWS'],
    demo: 'https://aws-study-hub.vercel.app',
    repo: 'https://github.com/Vktor-Dev/aws-study-hub',
    highlight: true,
  },
  {
    title: 'Portfolio website',
    description: 'Este mismo portfolio. Construido con Astro para máximo rendimiento estático. Diseño minimalista dark, desplegado en GitHub Pages con CI/CD.',
    tags: ['Astro', 'CSS', 'GitHub Actions', 'GitHub Pages'],
    repo: 'https://github.com/Vktor-Dev/Portfolio',
  },
];

const skills: Record<string, string[]> = {
  'Lenguajes': ['Python', 'Java', 'C++', 'SQL'],
  'Cloud & Datos': ['AWS', 'Power BI', 'Power Apps', 'GitHub Actions'],
  'Seguridad': ['Criptografía aplicada', 'Fundamentos de redes', 'OWASP'],
  'Herramientas': ['Git', 'Linux', 'VS Code', 'Docker'],
};
---
<Base
  title="Victor Ortega — Desarrollador"
  description="Desarrollador con interés en ciberseguridad y Cloud. Actualmente en Accenture, Málaga."
>
  <Nav />

  <main>
    <section style="border-top:none;padding:6rem 0 5rem;">
      <div class="container">
        <div style="display:inline-flex;align-items:center;gap:8px;margin-bottom:1.5rem;background:var(--bg3);border:1px solid var(--border);border-radius:20px;padding:5px 14px;">
          <span style="width:8px;height:8px;border-radius:50%;background:var(--accent2);display:inline-block;animation:pulse 2s ease-in-out infinite;"></span>
          <span style="font-size:0.8rem;color:var(--text2);">Disponible para proyectos</span>
        </div>
        <h1>
          Hola, soy Victor.<br />
          <span style="color:var(--accent);">Desarrollador</span> &amp;<br />
          futuro especialista en<br />
          seguridad.
        </h1>
        <p style="max-width:480px;margin:1.5rem 0 2rem;font-size:1rem;line-height:1.8;color:var(--text2);">
          No espero tener el título para construir cosas serias. Cada proyecto que publico
          es una excusa para entender algo más a fondo. Trabajo en Accenture y estudio
          Ingeniería Informática en Málaga.
        </p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;">
          <a href="#proyectos" class="btn primary">Ver proyectos</a>
          <a href="https://github.com/Vktor-Dev" target="_blank" rel="noopener" class="btn">GitHub ↗</a>
          <a href="https://www.linkedin.com/in/victor-ortega-dev" target="_blank" rel="noopener" class="btn">LinkedIn ↗</a>
          <a href="https://www.instagram.com/vitya13__/" target="_blank" rel="noopener" class="btn">Instagram ↗</a>
        </div>
      </div>
    </section>

    <section id="proyectos">
      <div class="container">
        <h2>Proyectos</h2>
        <div style="display:grid;gap:1rem;">
          {projects.map(p => <ProjectCard {...p} />)}
        </div>
      </div>
    </section>

    <section id="skills">
      <div class="container">
        <h2>Skills</h2>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1rem;">
          {Object.entries(skills).map(([cat, items]) => (
            <div class="card">
              <h3 style="margin-bottom:0.75rem;font-size:0.8rem;color:var(--text2);text-transform:uppercase;letter-spacing:.07em;font-weight:600;">{cat}</h3>
              <div style="display:flex;flex-wrap:wrap;gap:6px;">
                {items.map(s => <span class="tag">{s}</span>)}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="sobre-mi">
      <div class="container">
        <h2>Sobre mí</h2>
        <div class="card" style="max-width:600px;">
          <p style="line-height:1.85;margin-bottom:1rem;">
            Soy un desarrollador de 25 años basado en Málaga, actualmente trabajando en Accenture
            donde desarrollo soluciones con Power BI, Power Apps y herramientas de IA generativa.
            Estudio Ingeniería Informática.
          </p>
          <p style="line-height:1.85;margin-bottom:1.25rem;">
            No espero tener el título para construir cosas serias. Cada proyecto que
            publico es una excusa para entender algo más a fondo — desde implementar
            Diffie-Hellman desde cero hasta construir herramientas que uso yo mismo
            para estudiar. Sé exactamente hacia dónde voy.
          </p>
          <div style="display:flex;gap:8px;flex-wrap:wrap;">
            <span class="tag">Accenture</span>
            <span class="tag">Málaga, ES</span>
            <span class="tag">Ingeniería Informática</span>
          </div>
        </div>
      </div>
    </section>

    <section id="contacto">
      <div class="container">
        <h2>Contacto</h2>
        <p style="margin-bottom:1.5rem;max-width:420px;line-height:1.7;">
          ¿Quieres hablar de proyectos, colaboraciones o simplemente conectar? Escríbeme.
        </p>
        <div style="display:flex;gap:10px;flex-wrap:wrap;">
          <a href="https://www.linkedin.com/in/victor-ortega-dev" target="_blank" rel="noopener" class="btn primary">LinkedIn ↗</a>
          <a href="https://github.com/Vktor-Dev" target="_blank" rel="noopener" class="btn">GitHub ↗</a>
          <a href="https://www.instagram.com/vitya13__/" target="_blank" rel="noopener" class="btn">Instagram ↗</a>
        </div>
      </div>
    </section>

    <footer style="border-top:1px solid var(--border);padding:2rem 0;text-align:center;">
      <div class="container">
        <p style="font-size:0.8rem;color:var(--text2);">
          Construido con Astro · Desplegado en GitHub Pages
        </p>
      </div>
    </footer>
  </main>
</Base>

<style>
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}
</style>
